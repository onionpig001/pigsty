{
  "name": "pigsty",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "A personal AI agent farm for routing chat and webhook tasks to local workers.",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js",
    "demo": "node src/cli.js demo",
    "task": "node src/cli.js task",
    "run": "node src/cli.js run",
    "list": "node src/cli.js list",
    "prepare-pty": "node scripts/prepare-node-pty.js",
    "postinstall": "node scripts/prepare-node-pty.js",
    "check": "find src scripts public -name '*.js' -exec node --check {} \\; && node scripts/test-meeting-protocol.js",
    "test": "node scripts/test-meeting-protocol.js",
    "smoke:meeting": "node scripts/smoke-meeting-live.js"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "keywords": [
    "agent",
    "telegram-bot",
    "webhook",
    "automation",
    "local-ai"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onionpig001/pigsty.git"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "ws": "^8.20.0"
  }
}
