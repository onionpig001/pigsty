# Local status/API server
HOST=127.0.0.1
PORT=4188
WEBHOOK_TOKEN=change-me

# Web TUI console. For phone access on the same LAN, set HOST=0.0.0.0 and open:
# http://<server-lan-ip>:4188/
WEB_UI_ENABLED=true
WEB_UI_TOKEN=change-this-long-random-token
# Comma-separated public web/app origins allowed to call this backend.
# Blank defaults to * so hosted clients can connect; set exact origins for stricter deployments.
WEB_UI_ALLOWED_ORIGINS=
WEB_TUI_DEFAULT_CWD=..
WEB_TUI_ALLOWED_CWD_ROOTS=..
WEB_TUI_MAX_SESSIONS=8
# Installed TUI commands are detected automatically. Missing commands are hidden from the UI.
WEB_TUI_CODEX_BIN=codex
WEB_TUI_CODEX_ARGS=
WEB_TUI_CLAUDE_BIN=claude
WEB_TUI_CLAUDE_ARGS=
WEB_TUI_ALLOW_SHELL=false
WEB_TUI_SHELL_BIN=/bin/bash
WEB_TUI_SHELL_ARGS=

# Telegram. Create a bot with @BotFather, then send /whoami to get your numeric user id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLLING=true
TELEGRAM_ALLOWED_USER_IDS=

# Task behavior
AUTO_RUN=false
PLAIN_TEXT_AS_TASK=false
CONVERSATIONAL_MODE=true
MAX_ACTIVE_TASKS=1
TASK_TIMEOUT_MS=1800000

# Provider: mock or codex
AGENT_PROVIDER=mock
WORKSPACE_DIR=./workspace
CODEX_BIN=codex
CODEX_MODEL=
CODEX_PROFILE=
CODEX_SANDBOX=workspace-write
CODEX_FULL_AUTO=false

# Optional: allow a generic inbound webhook for other chat platforms.
WEBHOOK_CHANNEL_ENABLED=true
