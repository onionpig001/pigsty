# Local status/API server
HOST=127.0.0.1
PORT=4188
WEBHOOK_TOKEN=change-me

# Telegram. Create a bot with @BotFather, then send /whoami to get your numeric user id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLLING=true
TELEGRAM_ALLOWED_USER_IDS=

# Task behavior
AUTO_RUN=false
PLAIN_TEXT_AS_TASK=false
CONVERSATIONAL_MODE=true
MAX_ACTIVE_TASKS=1
TASK_TIMEOUT_MS=1800000

# Provider: mock or codex
AGENT_PROVIDER=mock
WORKSPACE_DIR=./workspace
CODEX_BIN=codex
CODEX_MODEL=
CODEX_PROFILE=
CODEX_SANDBOX=workspace-write
CODEX_FULL_AUTO=false

# Optional: allow a generic inbound webhook for other chat platforms.
WEBHOOK_CHANNEL_ENABLED=true
